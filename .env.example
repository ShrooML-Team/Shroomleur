# ===============================================
# Configuration de l'application Shroomleur API
# ===============================================

# Application
APP_NAME=Shroomleur API
APP_VERSION=0.1.0
DEBUG=false

# ===============================================
# Base de données PostgreSQL
# ===============================================
DATABASE_URL=postgresql://shroomleur:shroomleur@localhost:5432/shroomleur
DATABASE_ECHO=false

POSTGRES_DB=shroomleur
POSTGRES_USER=shroomleur
POSTGRES_PASSWORD=shroomleur
DB_PORT=5432

# ===============================================
# Sécurité & JWT
# ===============================================
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ===============================================
# Google OAuth 2.0
# ===============================================
# Obtenez ces valeurs depuis: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ===============================================
# CORS
# ===============================================
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# ===============================================
# Application port
# ===============================================
APP_PORT=8000
